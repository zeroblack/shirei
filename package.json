{
  "name": "shirei",
  "private": true,
  "version": "0.13.1",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "license": "MIT",
  "author": "Dionisio Fernández",
  "description": "A keyboard-first terminal cockpit for AI coding on macOS",
  "homepage": "https://github.com/zeroblack/shirei",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeroblack/shirei.git"
  },
  "bugs": {
    "url": "https://github.com/zeroblack/shirei/issues"
  },
  "keywords": [
    "terminal",
    "tauri",
    "ai-coding",
    "cli",
    "macos",
    "xterm",
    "developer-tools"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
