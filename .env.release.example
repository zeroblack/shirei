# App Store Connect API key para notarización de macOS (notarytool).
# Genera la key en: App Store Connect → Users and Access → Integrations →
# App Store Connect API. La private key (.p8) solo se descarga una vez.
#
# Copia este archivo a .env.release y completa los valores. .env.release está
# en .gitignore — nunca se commitea. Guarda el .p8 FUERA del repo.

# Issuer ID (aparece sobre la tabla de keys)
APPLE_API_ISSUER=

# Key ID (columna "Key ID" de tu key)
APPLE_API_KEY=

# Ruta al archivo AuthKey_<KeyID>.p8 descargado
APPLE_API_KEY_PATH=~/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
