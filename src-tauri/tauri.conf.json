{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shirei",
  "version": "0.12.1",
  "identifier": "dev.dioni.shirei",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Shirei",
        "width": 1000,
        "height": 660,
        "minWidth": 480,
        "minHeight": 320,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": ["$HOME/**/*"]
        }
      },
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: asset: http://asset.localhost",
        "media-src": "'self' asset: http://asset.localhost",
        "frame-src": "'self' asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "© 2026 Dionisio Fernández. MIT License.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.3",
      "signingIdentity": "Developer ID Application: Dionisio Fernandez (BKRV32HDYK)",
      "entitlements": "./Entitlements.plist"
    }
  }
}
